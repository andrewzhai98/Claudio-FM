# TTS provider.
TTS_PROVIDER=volcengine
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_SOURCE_ID=volc.service_type.10029
VOLCENGINE_TTS_VOICE_TYPE=en_female_nadia_tips_emo_v2_mars_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000
CALLER_TTS_SOURCE_ID=seed-tts-2.0
CALLER_TTS_VOICE_TYPE=zh_male_wennuanahu_uranus_bigtts

# Music provider.
MUSIC_PROVIDER=auto
NETEASE_API_BASE=http://127.0.0.1:3000
NETEASE_LEVEL=standard
NETEASE_COOKIE=

# LLM provider (deepseek | gemini | qwen | claude_cli)
LLM_PROVIDER=qwen
LLM_TIMEOUT_MS=120000

# Qwen (阿里云百炼, 新用户有免费额度)
QWEN_API_KEY=
QWEN_BASE_URL=https://bailian.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
